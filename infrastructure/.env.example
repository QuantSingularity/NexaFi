# NexaFi Environment Variables
# Copy this file to .env and fill in all values before running docker compose
# NEVER commit .env to version control

# ─── Redis ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
REDIS_PASSWORD=change_me_strong_redis_password

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=nexafi
# Generate: openssl rand -base64 32
RABBITMQ_PASSWORD=change_me_strong_rabbitmq_password
# Generate: openssl rand -hex 32
RABBITMQ_ERLANG_COOKIE=change_me_rabbitmq_erlang_cookie

# ─── Elasticsearch / Kibana ───────────────────────────────────────────────────
# Generate: openssl rand -base64 16
ELASTICSEARCH_PASSWORD=change_me_elasticsearch_password
# Each key must be >= 32 chars. Generate: openssl rand -base64 32
KIBANA_ENCRYPTION_KEY=change_me_kibana_encryption_key_32_chars_min
KIBANA_REPORTING_KEY=change_me_kibana_reporting_key_32_chars_min
KIBANA_SECURITY_KEY=change_me_kibana_security_key_32_chars_min_

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=change_me_jwt_secret_minimum_64_characters_for_security_compliance

# ─── Service Databases ────────────────────────────────────────────────────────
USER_DB_URL=postgresql://nexafi:password@localhost:5432/users
LEDGER_DB_URL=postgresql://nexafi:password@localhost:5432/ledger
PAYMENT_DB_URL=postgresql://nexafi:password@localhost:5432/payments
AI_DB_URL=postgresql://nexafi:password@localhost:5432/ai
ANALYTICS_DB_URL=postgresql://nexafi:password@localhost:5432/analytics
CREDIT_DB_URL=postgresql://nexafi:password@localhost:5432/credit
DOCUMENT_DB_URL=postgresql://nexafi:password@localhost:5432/documents

# ─── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_change_me
PAYPAL_CLIENT_SECRET=change_me_paypal_secret

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-change_me_openai_key

# ─── AWS (dev only - use IRSA in production) ──────────────────────────────────
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_REGION=us-west-2
S3_BUCKET_NAME=nexafi-dev-documents
