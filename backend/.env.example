# ─── Security ──────────────────────────────────────────────────────────────
# REQUIRED: Set a long, random secret key in production
SECRET_KEY=nexafi-change-this-to-a-long-random-string-in-production

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── RabbitMQ ─────────────────────────────────────────────────────────────
RABBITMQ_USER=nexafi
RABBITMQ_PASSWORD=nexafi123

# ─── Service URLs (used by api-gateway) ───────────────────────────────────
USER_SERVICE_URL=http://user-service:5001
LEDGER_SERVICE_URL=http://ledger-service:5002
PAYMENT_SERVICE_URL=http://payment-service:5003
AI_SERVICE_URL=http://ai-service:5004

# ─── Email (notification-service) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── FAPI Keys (auth-service) ─────────────────────────────────────────────
FAPI_PRIVATE_KEY=/app/keys/private_key.pem
FAPI_PUBLIC_KEY=/app/keys/public_key.pem

# ─── Debug (set to "true" only in development) ────────────────────────────
FLASK_DEBUG=false
